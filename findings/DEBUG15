# DEBUG15 - Kernel Configuration for Development and Debugging (FreeBSD 15)
# Based on GENERIC, but with heavy diagnostic flags for systems engineering.

include GENERIC
ident   DEBUG15

# Advanced Debugging Options
options         DDB                     # Interactive console-based debugger
options         GDB                     # Remote GDB (serial/stub)
options         KDB                     # Kernel debugger framework
options         KDB_TRACE               # Print stack trace to console on panics

# Integrity Diagnostics (Critical for new feature development)
options         INVARIANTS              # Internal kernel assertion checks
options         INVARIANT_SUPPORT       # Support for the above
options         WITNESS                 # Detection of Deadlocks and LORs (Lock Order Reversal)
options         WITNESS_SKIPSPIN        # Skip spinlocks to reduce overhead and false positives

# Tracing
options         KTR                     # Kernel Trace Facility (circular log)
options         KTR_MASK=KTR_ALL        # Trace all subsystems by default
options         KTR_COMPILE=(KTR_ALL)   

# Development Optimizations
makeoptions     DEBUG=-g                # Ensure DWARF symbols for GDB
makeoptions     WITH_CTF=1              # Compressed Type Format for DTrace
